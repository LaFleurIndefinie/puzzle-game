# ============================================
# 旗舰版报表 SQL 生成技能 - 环境变量配置
# ============================================
# 使用方式：复制此文件为 .env，填入实际值
# cp .env.example .env
# ============================================

# ========== 开放平台鉴权 ==========
API_BASE_URL=https://your-domain.yonyoucloud.com/
API_APP_KEY=your_app_key_here
API_APP_SECRET=your_app_secret_here

# ========== 数据库连接 ==========
DB_ENABLED=true

# 数据库类型: mysql | postgresql | oracle | dm | mssql
DB_DRIVER=mysql

DB_HOST=your_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
# 逻辑库/库名。MySQL、PostgreSQL、SQL Server 必填；Oracle 可忽略（用 DB_SERVICE_NAME）；达梦可留空（连默认实例，或填实例/模式名）
DB_NAME=your_db_name
# Oracle 专用：服务名（如 ORCL、ORCLPDB1）；与 DB_NAME 无关
# DB_SERVICE_NAME=ORCL
DB_CHARSET=utf8mb4

# ========== 租户配置 ==========
YONBIP_TENANT_ID=your_tenant_id

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=

# ========== 环境配置 ==========
ENV_NAME=development
ENV_DEBUG=false
