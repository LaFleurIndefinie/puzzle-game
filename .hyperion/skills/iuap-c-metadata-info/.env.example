# ============================================
# 旗舰版元数据查询技能 - 环境变量配置
# ============================================
# 使用方式：复制此文件为 .env，填入实际值
# cp .env.example .env
# ============================================

# ========== 开放平台鉴权 ==========
API_BASE_URL=https://your-domain.yonyoucloud.com/
API_APP_KEY=your_app_key_here
API_APP_SECRET=your_app_secret_here

# ========== 租户配置 ==========
YONBIP_TENANT_ID=your_tenant_id

# ========== 环境配置 ==========
ENV_NAME=development
ENV_DEBUG=false
